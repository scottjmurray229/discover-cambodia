---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'History & Heritage', url: '/history/' },
];

const pageTitle = 'Cambodia History — From Angkor Empire to Modern Recovery';
const pageDescription = 'From the golden age of the Khmer Empire to the darkness of the Khmer Rouge and Cambodia\'s remarkable recovery — trace history through the places where it still stands.';

interface TimelineEvent {
  date: string;
  year: number;
  title: string;
  location: string;
  slug?: string | string[];
  description: string;
  whatToSee?: string;
  side: 'left' | 'right';
  era: 'empire' | 'colonial' | 'conflict' | 'recovery';
}

const timeline: TimelineEvent[] = [
  {
    date: '802 AD',
    year: 802,
    title: 'Foundation of the Khmer Empire',
    location: 'Angkor Region',
    slug: 'siem-reap',
    description: 'King Jayavarman II declared independence from Java and established the Khmer Empire with its capital near modern-day Siem Reap. He proclaimed himself a "universal monarch" in a ceremony on Phnom Kulen mountain, unifying the Khmer kingdoms and launching the greatest civilization in Southeast Asian history.',
    whatToSee: 'Phnom Kulen National Park — the sacred mountain where the empire was founded. River of a Thousand Lingas, ancient carvings, and waterfalls. A day trip from Siem Reap.',
    side: 'left',
    era: 'empire',
  },
  {
    date: '1113–1150 AD',
    year: 1113,
    title: 'Construction of Angkor Wat',
    location: 'Angkor, Siem Reap',
    slug: 'siem-reap',
    description: 'King Suryavarman II built Angkor Wat as a Hindu temple dedicated to Vishnu — the largest religious monument ever constructed. Over 300,000 workers and 6,000 elephants labored for 37 years to create this masterpiece of Khmer architecture. It would later become a Buddhist temple.',
    whatToSee: 'Angkor Wat — the crown jewel of Cambodian heritage. Sunrise visits, the 800m bas-relief gallery depicting Hindu epics, and the central tower are must-sees. Budget a full day minimum.',
    side: 'right',
    era: 'empire',
  },
  {
    date: '1181–1218 AD',
    year: 1181,
    title: 'Jayavarman VII & the Golden Age',
    location: 'Angkor Thom, Siem Reap',
    slug: 'siem-reap',
    description: 'The last great Khmer king built Angkor Thom, the Bayon temple with its 216 smiling stone faces, Ta Prohm, Preah Khan, and a network of hospitals and roads across the empire. He converted the empire to Mahayana Buddhism and expanded Khmer territory to its greatest extent — stretching across modern Thailand, Laos, Vietnam, and Myanmar.',
    whatToSee: 'Angkor Thom complex — the Bayon faces, Ta Prohm (the "jungle temple"), Preah Khan, and the Terrace of the Elephants. Allow 2–3 days for the full Angkor Archaeological Park.',
    side: 'left',
    era: 'empire',
  },
  {
    date: '15th Century',
    year: 1431,
    title: 'Fall of Angkor',
    location: 'Angkor Region',
    slug: 'siem-reap',
    description: 'After repeated Thai invasions and the sacking of Angkor in 1431, the Khmer capital shifted south to Phnom Penh. The great temples were gradually reclaimed by the jungle over the following centuries. Angkor Wat was never completely abandoned — Buddhist monks maintained it — but the empire that built it was gone.',
    side: 'right',
    era: 'empire',
  },
  {
    date: '1863',
    year: 1863,
    title: 'French Protectorate Established',
    location: 'Phnom Penh',
    slug: 'phnom-penh',
    description: 'King Norodom signed a treaty making Cambodia a French protectorate — trading sovereignty for protection against Thai and Vietnamese encroachment. French colonial rule would last 90 years, reshaping Cambodia\'s architecture, infrastructure, and education system while exploiting its resources.',
    whatToSee: 'French colonial architecture along the Phnom Penh riverfront, the National Museum (built in Khmer style by French architects), and the Royal Palace compound.',
    side: 'left',
    era: 'colonial',
  },
  {
    date: '1860s–1900s',
    year: 1870,
    title: 'Rediscovery of Angkor',
    location: 'Siem Reap',
    slug: 'siem-reap',
    description: 'French naturalist Henri Mouhot popularized the "discovery" of Angkor Wat to the Western world in the 1860s (local Cambodians always knew it was there). French archaeologists spent decades clearing jungle, cataloguing ruins, and restoring temples. The work established Angkor as one of the world\'s great archaeological sites.',
    whatToSee: 'The Conservation d\'Angkor workshop in Siem Reap (limited access) continues restoration work. The Angkor National Museum in Siem Reap provides excellent context.',
    side: 'right',
    era: 'colonial',
  },
  {
    date: '1953',
    year: 1953,
    title: 'Independence from France',
    location: 'Phnom Penh',
    slug: 'phnom-penh',
    description: 'King Norodom Sihanouk secured Cambodia\'s independence from France through diplomatic pressure and a "royal crusade." November 9, 1953 is celebrated annually as Independence Day. The Independence Monument in Phnom Penh — shaped like an Angkorian lotus tower — commemorates this achievement.',
    whatToSee: 'The Independence Monument on Norodom Boulevard — dramatically illuminated at night, especially during Independence Day celebrations in November.',
    side: 'left',
    era: 'colonial',
  },
  {
    date: '1953–1970',
    year: 1960,
    title: 'Sihanouk\'s Cambodia — The Golden Era',
    location: 'Phnom Penh & Nationwide',
    slug: 'phnom-penh',
    description: 'Under Sihanouk, Cambodia experienced a cultural renaissance. Phnom Penh was called the "Pearl of Asia" — a sophisticated city of French-influenced architecture, thriving arts, and relative peace. New Khmer Architecture blended modernism with traditional forms. This brief golden era would end abruptly.',
    whatToSee: 'The former Olympic Stadium, Central Market (Art Deco), and surviving New Khmer Architecture buildings across Phnom Penh. The Royal Palace and Silver Pagoda complex.',
    side: 'right',
    era: 'colonial',
  },
  {
    date: '1970–1975',
    year: 1970,
    title: 'Civil War & US Bombing Campaign',
    location: 'Across Cambodia',
    description: 'A US-backed coup deposed Sihanouk in 1970. Cambodia was dragged into the Vietnam War, with massive US bombing campaigns (2.7 million tons of bombs — more than the Allies dropped in all of WWII) devastating the countryside and driving peasants toward the Khmer Rouge insurgency. An estimated 100,000–150,000 Cambodians died in the bombing.',
    side: 'left',
    era: 'conflict',
  },
  {
    date: 'April 17, 1975',
    year: 1975,
    title: 'Khmer Rouge Takes Phnom Penh',
    location: 'Phnom Penh',
    slug: 'phnom-penh',
    description: 'The Khmer Rouge marched into Phnom Penh and immediately evacuated the entire city — forcing 2 million residents into the countryside at gunpoint. Year Zero had begun. Money was abolished, religion banned, schools closed. The next four years would become one of the darkest chapters in human history.',
    whatToSee: 'Tuol Sleng Genocide Museum (S-21) — a former high school converted into a torture prison. The building, cells, and photographs of victims remain as they were. A profoundly difficult but essential visit.',
    side: 'right',
    era: 'conflict',
  },
  {
    date: '1975–1979',
    year: 1977,
    title: 'The Killing Fields',
    location: 'Choeung Ek & Nationwide',
    slug: 'phnom-penh',
    description: 'Under Pol Pot\'s regime, an estimated 1.5–2 million Cambodians — nearly a quarter of the population — died from execution, starvation, forced labor, and disease. Intellectuals, monks, ethnic minorities, and anyone suspected of disloyalty were killed. Over 20,000 mass graves have been discovered across Cambodia.',
    whatToSee: 'Choeung Ek Killing Fields — 15 km south of Phnom Penh. The memorial stupa holds thousands of skulls. Audio tours guide you through the site\'s horrific history. Allow 2–3 hours. Combine with Tuol Sleng for a full-day heritage visit.',
    side: 'left',
    era: 'conflict',
  },
  {
    date: 'January 7, 1979',
    year: 1979,
    title: 'Fall of the Khmer Rouge',
    location: 'Phnom Penh',
    slug: 'phnom-penh',
    description: 'Vietnamese forces invaded and captured Phnom Penh, ending the Khmer Rouge regime. Survivors emerged from the countryside to find their cities empty, their families gone, and their country devastated. January 7 is celebrated annually as Victory over Genocide Day.',
    side: 'right',
    era: 'conflict',
  },
  {
    date: '1991–1993',
    year: 1991,
    title: 'Paris Peace Accords & UN Mission',
    location: 'Phnom Penh',
    slug: 'phnom-penh',
    description: 'The Paris Peace Accords brought a formal end to conflict, and the United Nations Transitional Authority in Cambodia (UNTAC) organized elections in 1993. Cambodia became a constitutional monarchy again. The country began its long road to recovery with international support and the return of diaspora Cambodians.',
    side: 'left',
    era: 'recovery',
  },
  {
    date: '1992',
    year: 1992,
    title: 'Angkor Becomes a UNESCO World Heritage Site',
    location: 'Siem Reap',
    slug: 'siem-reap',
    description: 'UNESCO designated the Angkor Archaeological Park as a World Heritage Site, triggering international conservation efforts and eventually transforming Siem Reap from a dusty provincial town into Cambodia\'s tourism capital. Today over 2 million visitors per year explore the temples.',
    whatToSee: 'The entire Angkor Archaeological Park — 400+ square kilometers of temples, reservoirs, and ancient infrastructure. The three-day pass ($62) is the best value for thorough exploration.',
    side: 'right',
    era: 'recovery',
  },
  {
    date: '2000s–Present',
    year: 2010,
    title: 'Cambodia\'s Remarkable Recovery',
    location: 'Nationwide',
    description: 'Cambodia has experienced sustained economic growth, rapid development, and a tourism boom. Phnom Penh has transformed into a modern capital with skyscrapers, craft cocktail bars, and a thriving food scene. Siem Reap has world-class hotels. Kampot, Koh Rong, and Battambang have emerged as distinctive destinations. The scars of the past remain, but Cambodia\'s resilience is extraordinary.',
    side: 'left',
    era: 'recovery',
  },
  {
    date: 'Present Day',
    year: 2026,
    title: 'The Heritage That Remains',
    location: 'All Destinations',
    description: 'From Angkor\'s sublime temples to the Killing Fields\' stark memorial, from French colonial elegance to the vibrant modern capital — Cambodia\'s history is layered, complex, and present everywhere you look. Understanding this history transforms your visit from sightseeing to something deeper.',
    side: 'right',
    era: 'recovery',
  },
];

const eraLabels: Record<string, string> = {
  empire: 'The Khmer Empire — 802–1431 AD',
  colonial: 'Colonial Era & Independence — 1863–1970',
  conflict: 'War & Genocide — 1970–1991',
  recovery: 'Recovery & Renewal — 1991–Present',
};

const eraGradients: Record<string, string> = {
  empire: 'linear-gradient(135deg, #78350F 0%, #D97706 100%)',
  colonial: 'linear-gradient(135deg, #1565C0 0%, #42A5F5 100%)',
  conflict: 'linear-gradient(135deg, #B71C1C 0%, #D32F2F 100%)',
  recovery: 'linear-gradient(135deg, #1B5E20 0%, #388E3C 100%)',
};

const eraColors: Record<string, string> = {
  empire: '#D97706',
  colonial: '#1565C0',
  conflict: '#D32F2F',
  recovery: '#388E3C',
};

// Geo coordinates for map markers
const geoLookup: Record<string, { lat: number; lng: number }> = {
  'phnom-penh': { lat: 11.5564, lng: 104.9282 },
  'siem-reap': { lat: 13.3633, lng: 103.8564 },
};

// Build map markers from timeline events that have slugs
const wwiiMapMarkers = timeline
  .filter(e => e.slug)
  .map(e => {
    const slugs = Array.isArray(e.slug) ? e.slug : [e.slug!];
    const primarySlug = slugs[0];
    const geo = geoLookup[primarySlug];
    if (!geo) return null;
    return {
      lat: geo.lat,
      lng: geo.lng,
      title: e.title,
      date: e.date,
      location: e.location,
      era: e.era,
      color: eraColors[e.era],
      url: `/destinations/${primarySlug}/`,
    };
  })
  .filter(Boolean);

// History card videos — 7 clips cycled across timeline events
const ww2CardVideos = Array.from({ length: 7 }, (_, i) => `/videos/pillar/history-card-${i + 1}.mp4`);

---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  pageType="destination"
  schemaData={{ title: pageTitle, description: pageDescription }}
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <header class="ww2-hero">
    <video class="ww2-hero-video" autoplay muted loop playsinline preload="metadata">
      <source src="/videos/pillar/history-hero.mp4" type="video/mp4" />
    </video>
    <div class="ww2-hero-gradient"></div>
    <div class="ww2-hero-noise"></div>
    <div class="ww2-hero-content">
      <h1 class="ww2-hero-title">History of Cambodia</h1>
      <p class="ww2-hero-subtitle">From the golden age of Angkor to the darkness of the Khmer Rouge and the country's remarkable recovery — trace history through the places where it still stands.</p>
      <div class="ww2-hero-meta">
        <div class="ww2-hero-meta-item">
          <span class="ww2-hero-meta-label">Events</span>
          <span class="ww2-hero-meta-value">15</span>
        </div>
        <div class="ww2-hero-meta-item">
          <span class="ww2-hero-meta-label">Destinations</span>
          <span class="ww2-hero-meta-value">2</span>
        </div>
        <div class="ww2-hero-meta-item">
          <span class="ww2-hero-meta-label">Timeline</span>
          <span class="ww2-hero-meta-value">802 AD–Present</span>
        </div>
      </div>
    </div>
    <div class="ww2-scroll-hint">Scroll<br />&#8595;</div>
  </header>

  <!-- Breadcrumb -->
  <div class="container-content">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Personal intro -->
  <section class="ww2-personal reveal">
    <div class="container-content">
      <blockquote class="ww2-personal-quote">
        <p>Cambodia's history hit me harder than anywhere else I've traveled. Walking through Tuol Sleng, standing in the killing fields at Choeung Ek, and then watching kids laugh and play at the temples of Angkor the next day — the contrast is overwhelming. This is a country that went from building one of the greatest civilizations in human history to enduring one of its worst genocides, and somehow came out the other side. Understanding that arc makes every temple, every market, every conversation in Cambodia feel different. I think it's impossible to truly appreciate this country without knowing what it's been through.</p>
        <cite>— Scott</cite>
      </blockquote>
    </div>
  </section>

  <!-- View Toggle -->
  <div class="container-content" style="padding-top: var(--space-2); padding-bottom: var(--space-4);">
    <div class="ww2-view-toggle">
      <button class="ww2-toggle-btn active" id="ww2BtnTimeline">Timeline</button>
      <button class="ww2-toggle-btn" id="ww2BtnMap">Map</button>
    </div>
  </div>

  <!-- Timeline -->
  <div id="ww2TimelineView">
  <section class="ww2-timeline-section">
    <div class="container-content">
      <h2 class="ww2-timeline-heading reveal">A Thousand Years of History</h2>
      <p class="ww2-timeline-sub reveal">Cambodia's story spans the rise and fall of the greatest empire in Southeast Asia, colonial rule, independence, genocide, and a remarkable recovery. These are the places where that history is still visible — and still worth understanding.</p>

      <div class="ww2-timeline">
        <div class="ww2-timeline-line" aria-hidden="true"></div>

        {(() => {
          let lastEra = '';
          return timeline.map((event, idx) => {
            const showEra = event.era !== lastEra;
            lastEra = event.era;
            const slugs = Array.isArray(event.slug) ? event.slug : event.slug ? [event.slug] : [];
            const primarySlug = slugs[0];
            const cardVideo = ww2CardVideos[idx % ww2CardVideos.length];
            return (
              <>
                {showEra && (
                  <div class="ww2-era-marker reveal">
                    <div class="ww2-era-pill" style={`background: ${eraGradients[event.era]};`}>
                      {eraLabels[event.era]}
                    </div>
                  </div>
                )}
                <div class={`ww2-event ww2-event--${event.side} reveal`}>
                  <div class="ww2-event-dot" style={`background: ${eraGradients[event.era]};`}></div>
                  {primarySlug && slugs.length === 1 ? (
                    <a href={`/destinations/${primarySlug}/`} class="ww2-event-card">
                      <div class="ww2-event-media" style={`background: ${eraGradients[event.era]};`}>
                        <video class="ww2-event-video" muted loop playsinline preload="none" data-src={cardVideo}></video>
                        <span class="ww2-event-date-badge">{event.date}</span>
                      </div>
                      <div class="ww2-event-body">
                        <h3 class="ww2-event-title">{event.title}</h3>
                        <p class="ww2-event-location">{event.location}</p>
                        <p class="ww2-event-desc">{event.description}</p>
                        {event.whatToSee && (
                          <div class="ww2-event-see">
                            <span class="ww2-event-see-label">What to see today:</span>
                            <p class="ww2-event-see-text">{event.whatToSee}</p>
                          </div>
                        )}
                        <span class="ww2-event-cta">Explore {event.location.split(',')[0]} &rarr;</span>
                      </div>
                      <div class="ww2-event-overlay">
                        <p class="ww2-event-overlay-text">{event.description}</p>
                        {event.whatToSee && (
                          <div class="ww2-event-overlay-see">
                            <span class="ww2-event-overlay-see-label">What to see today:</span>
                            <p>{event.whatToSee}</p>
                          </div>
                        )}
                        <span class="ww2-event-overlay-cta">Explore {event.location.split(',')[0]} &rarr;</span>
                      </div>
                    </a>
                  ) : primarySlug ? (
                    <div class="ww2-event-card ww2-event-card--multi">
                      <div class="ww2-event-media" style={`background: ${eraGradients[event.era]};`}>
                        <video class="ww2-event-video" muted loop playsinline preload="none" data-src={cardVideo}></video>
                        <span class="ww2-event-date-badge">{event.date}</span>
                      </div>
                      <div class="ww2-event-body">
                        <h3 class="ww2-event-title">{event.title}</h3>
                        <p class="ww2-event-location">{event.location}</p>
                        <p class="ww2-event-desc">{event.description}</p>
                        {event.whatToSee && (
                          <div class="ww2-event-see">
                            <span class="ww2-event-see-label">What to see today:</span>
                            <p class="ww2-event-see-text">{event.whatToSee}</p>
                          </div>
                        )}
                        <div class="ww2-event-cta-group">
                          {slugs.map((s) => (
                            <a href={`/destinations/${s}/`} class="ww2-event-cta ww2-event-cta-link">Explore {s.charAt(0).toUpperCase() + s.slice(1)} &rarr;</a>
                          ))}
                        </div>
                      </div>
                    </div>
                  ) : (
                    <div class="ww2-event-card ww2-event-card--nolink">
                      <div class="ww2-event-media" style={`background: ${eraGradients[event.era]};`}>
                        <video class="ww2-event-video" muted loop playsinline preload="none" data-src={cardVideo}></video>
                        <span class="ww2-event-date-badge">{event.date}</span>
                      </div>
                      <div class="ww2-event-body">
                        <h3 class="ww2-event-title">{event.title}</h3>
                        <p class="ww2-event-location">{event.location}</p>
                        <p class="ww2-event-desc">{event.description}</p>
                      </div>
                    </div>
                  )}
                </div>
              </>
            );
          });
        })()}
      </div>
    </div>
  </section>

  </div><!-- /ww2TimelineView -->

  <!-- Map View (hidden by default) -->
  <div id="ww2MapView" style="display:none;">
    <section style="padding: var(--space-4) 0 var(--space-8);">
      <div class="container-content">
        <div class="ww2-map-container" id="ww2MapContainer">
          <div class="ww2-map-tooltip" id="ww2MapTooltip">
            <div class="ww2-map-tooltip-title" id="ww2TooltipTitle"></div>
            <div class="ww2-map-tooltip-date" id="ww2TooltipDate"></div>
            <div class="ww2-map-tooltip-location" id="ww2TooltipLocation"></div>
          </div>
          <div id="ww2LeafletMap"></div>
          <div class="ww2-map-legend">
            <div class="ww2-map-legend-item"><div class="ww2-map-legend-dot" style="background:#D97706;"></div>Empire</div>
            <div class="ww2-map-legend-item"><div class="ww2-map-legend-dot" style="background:#1565C0;"></div>Colonial</div>
            <div class="ww2-map-legend-item"><div class="ww2-map-legend-dot" style="background:#D32F2F;"></div>Conflict</div>
            <div class="ww2-map-legend-item"><div class="ww2-map-legend-dot" style="background:#388E3C;"></div>Recovery</div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Bottom CTA -->
  <section class="ww2-cta-section reveal">
    <div class="container-content">
      <div class="ww2-cta-card">
        <h2 class="ww2-cta-heading">Plan a Heritage Trip</h2>
        <p class="ww2-cta-text">Tell our AI planner you want to explore Cambodia's history and it will build an itinerary — Angkor temples, the Killing Fields, the Royal Palace, Tuol Sleng, and more.</p>
        <a href="/plan/" class="ww2-cta-button">Start Planning &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={[
    { question: "What is the history of Cambodia?", answer: "Cambodia's history spans over a thousand years. The Khmer Empire (802-1431 AD) built Angkor Wat and ruled much of Southeast Asia. After the empire's decline, Cambodia endured centuries of foreign influence, became a French protectorate in 1863, gained independence in 1953, then suffered the devastating Khmer Rouge genocide (1975-1979) that killed nearly 2 million people. Since the 1991 Paris Peace Accords, Cambodia has undergone a remarkable recovery." },
    { question: "Can you visit historical sites in Cambodia today?", answer: "Yes — Cambodia's historical sites are among the most visited in Southeast Asia. Angkor Archaeological Park has over 1,000 temples across 400 square kilometers. Tuol Sleng Genocide Museum and the Killing Fields at Choeung Ek are open daily in Phnom Penh. The Royal Palace and Silver Pagoda, the National Museum, and numerous colonial-era buildings are all accessible. Most sites charge $3-37 entrance." },
    { question: "What happened during the Khmer Rouge period?", answer: "The Khmer Rouge, led by Pol Pot, seized power in April 1975 and emptied Cambodia's cities in an attempt to create an agrarian utopia. Over nearly four years, an estimated 1.7-2.2 million people — roughly a quarter of the population — died from execution, starvation, disease, and forced labor. The regime fell in January 1979 when Vietnamese forces invaded, but the effects are still felt today." },
    { question: "How do I visit Angkor Wat and the temples?", answer: "Angkor Archaeological Park is accessed from Siem Reap. Tickets cost $37 for a one-day pass, $62 for three days, or $72 for seven days. The park is open sunrise to sunset. Most visitors hire a tuk-tuk driver ($15-20/day) or rent an e-bike. The Small Circuit (Angkor Wat, Bayon, Ta Prohm) takes a full day. I recommend at least three days to avoid temple fatigue and appreciate the sites properly." },
    { question: "Should I visit the Killing Fields and Tuol Sleng?", answer: "Yes, if you can handle it emotionally. Tuol Sleng (S-21 Prison) in Phnom Penh is a former high school converted into a torture facility — the audio guide is essential. Choeung Ek (the Killing Fields) is 17 km south of the city and takes about 2 hours. Visit both on the same day. Allow time afterward to process. These sites are important for understanding modern Cambodia and honoring the victims." },
    { question: "What is the best order to experience Cambodia's history?", answer: "I recommend starting in Siem Reap with Angkor's temples to understand the Khmer Empire at its peak. Then travel to Phnom Penh for the Royal Palace, National Museum, and the Khmer Rouge sites (Tuol Sleng and Choeung Ek). This chronological approach — empire, colonialism, independence, genocide, recovery — gives the full emotional arc. The contrast between Angkor's grandeur and the Killing Fields is profound." },
  ]} />

  <!-- Email Capture -->
  <div class="container-content reveal" style="padding-bottom: var(--space-6);">
    <EmailCapture
      leadMagnet="Get My Free Cambodia History & Heritage Guide"
      description="A chronological PDF guide to Cambodia's most important historical sites — with directions, opening hours, and the history behind each location."
      bullets={[
        'Angkor temple circuit planner with suggested routes',
        'Phnom Penh heritage day — Tuol Sleng, Killing Fields, Royal Palace',
        'Timeline overview from Khmer Empire to modern recovery',
        'Suggested 5-day history and heritage itinerary',
      ]}
      guideTag="pillar-history"
    />
  </div>

  <!-- Cross-links -->
  <section class="ww2-crosslinks reveal">
    <div class="container-content">
      <h3 class="ww2-crosslinks-heading">Explore More</h3>
      <div class="ww2-crosslinks-grid">
        <a href="/festivals/" class="ww2-crosslink-card">
          <span class="ww2-crosslink-icon">&#127914;</span>
          <span class="ww2-crosslink-label">Festival Calendar</span>
          <span class="ww2-crosslink-desc">14 festivals across 4 destinations</span>
        </a>
        <a href="/cuisine/" class="ww2-crosslink-card">
          <span class="ww2-crosslink-icon">&#127860;</span>
          <span class="ww2-crosslink-label">Food & Cuisine</span>
          <span class="ww2-crosslink-desc">17 dishes across 10 destinations</span>
        </a>
        <a href="/practical/" class="ww2-crosslink-card">
          <span class="ww2-crosslink-icon">&#127890;</span>
          <span class="ww2-crosslink-label">Travel Essentials</span>
          <span class="ww2-crosslink-desc">Visa, money, transport & safety</span>
        </a>
      </div>
